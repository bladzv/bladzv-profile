---
import { Linkedin, Github, Heart } from '@lucide/astro';
---

<footer class="relative z-10 border-t border-cyber-border/30">
  <div class="section-container py-8 md:py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Social links -->
      <div class="flex items-center gap-4">
        <a
          href="https://www.linkedin.com/in/bloodyvelasco/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-cyber-muted hover:text-cyber-blue transition-colors group"
          aria-label="LinkedIn Profile"
        >
          <Linkedin class="w-5 h-5 group-hover:scale-110 transition-transform" />
          <span class="text-sm font-mono hidden sm:inline">LinkedIn</span>
        </a>
        <a
          href="https://github.com/bladzv"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-cyber-muted hover:text-cyber-text transition-colors group"
          aria-label="GitHub Profile"
        >
          <Github class="w-5 h-5 group-hover:scale-110 transition-transform" />
          <span class="text-sm font-mono hidden sm:inline">GitHub</span>
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-xs text-cyber-muted/60 font-mono flex items-center gap-1">
        &copy; {new Date().getFullYear()} Bloodymer S. Velasco
      </p>
      <div class="ml-4">
        <button
          id="particles-toggle"
          class="text-xs text-cyber-muted/60 font-mono hover:text-cyber-green transition-colors rounded px-2 py-1"
          aria-pressed="false"
          aria-label="Toggle particle background"
        >
          Toggle Particles
        </button>
      </div>
    </div>
  </div>
</footer>

<script>
  (function () {
    const btn = document.getElementById('particles-toggle');
    if (!btn) return;
    function updateLabel() {
      try {
        const disabled = localStorage.getItem('particles-disabled') === '1';
        btn.setAttribute('aria-pressed', String(!disabled));
        btn.textContent = disabled ? 'Enable Particles' : 'Disable Particles';
      } catch (e) {}
    }
    btn.addEventListener('click', () => {
      try {
        const disabled = localStorage.getItem('particles-disabled') === '1';
        localStorage.setItem('particles-disabled', disabled ? '0' : '1');
        window.dispatchEvent(new Event('particles:toggle'));
        updateLabel();
      } catch (e) {}
    });
    updateLabel();
  })();
</script>
