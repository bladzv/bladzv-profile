---
import { Linkedin, Github } from '@lucide/astro';
---

<footer class="relative z-10 border-t border-cyber-border/30">
  <div class="section-container py-8 md:py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Social links -->
      <div class="flex items-center gap-4">
        <a
          href="https://www.linkedin.com/in/bloodyvelasco/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-cyber-muted hover:text-cyber-blue transition-colors group"
          aria-label="LinkedIn Profile"
        >
          <Linkedin class="w-5 h-5 group-hover:scale-110 transition-transform" />
          <span class="text-sm font-mono hidden sm:inline">LinkedIn</span>
        </a>
        <a
          href="https://github.com/bladzv"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-cyber-muted hover:text-cyber-text transition-colors group"
          aria-label="GitHub Profile"
        >
          <Github class="w-5 h-5 group-hover:scale-110 transition-transform" />
          <span class="text-sm font-mono hidden sm:inline">GitHub</span>
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-xs text-cyber-muted/60 font-mono flex items-center gap-1">
        &copy; {new Date().getFullYear()} Bloodymer S. Velasco
      </p>
    </div>
  </div>
</footer>
