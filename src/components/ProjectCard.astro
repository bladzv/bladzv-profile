---
import { Globe, Lock, ExternalLink, Play, Construction } from '@lucide/astro';

export interface ProjectData {
  title: string;
  description: string;
  language: string;
  stack?: string;
  url?: string;
  homepage?: string;
  visibility: 'public' | 'private';
  blur?: boolean; // when true on private entries show generic blurred text
  status?: 'active' | 'ongoing' | 'archived';
}

interface Props {
  project: ProjectData;
}

const { project } = Astro.props;

/** GitHub-style language colors */
const langColors: Record<string, string> = {
  JavaScript: '#f1e05a',
  TypeScript: '#3178c6',
  Python: '#3572A5',
  'C++': '#f34b7d',
  Shell: '#89e051',
  Bash: '#89e051',
  HTML: '#e34c26',
  CSS: '#563d7c',
  Unknown: '#8888aa',
};

const dotColor = langColors[project.language] || langColors.Unknown;
const placeholder = 'Closed-source project';
const useBlur = project.blur && project.visibility === 'private';
const truncatedDesc =
  useBlur
    ? placeholder
    : project.description.length > 140
    ? project.description.slice(0, 137) + '...'
    : project.description;
---

<div class="glass-card p-5 flex flex-col h-full group hover:border-cyber-green/30 transition-all duration-300 hover:shadow-[0_0_24px_rgba(0,255,136,0.06)] hover:-translate-y-1" data-private={project.visibility === 'private'}>
    <!-- Header: title + badges (always visible) -->
    <div class="flex items-start justify-between gap-2 mb-3">
      <h3 class="text-base font-semibold font-mono text-cyber-text group-hover:text-cyber-green transition-colors">
        {project.url ? (
          <a href={project.url} target="_blank" rel="noopener noreferrer" class="hover:underline" aria-label={`Open ${project.title}`}>
            {project.title}
          </a>
        ) : (
          project.title
        )}
      </h3>
      <div class="flex items-center gap-2 flex-shrink-0">
      {project.status === 'ongoing' && (
        <span class="badge-ongoing">
          <Construction class="w-3 h-3" />
          Ongoing
        </span>
      )}
      {project.visibility === 'public' ? (
        <span class="badge-public">
          <Globe class="w-3 h-3" />
          Public
        </span>
      ) : (
        <span class="badge-private">
          <Lock class="w-3 h-3" />
          Private
        </span>
      )}
    </div>
  </div>

  <!-- Description area (can be blurred placeholder) -->
  {useBlur ? (
    <div class="relative flex-grow mb-4 overflow-hidden flex items-center justify-center">
      <div class="absolute inset-0 bg-cyber-bg/60 filter blur-sm">
        <!-- decorative blurred text/content to make effect visible -->
        <span class="absolute inset-0 flex flex-col items-center justify-center text-cyber-muted/30 text-sm">
          <span>████████████████████</span>
          <span>████████████████████</span>
          <span>████████████████████</span>
        </span>
      </div>
      <p class="relative z-10 text-xl font-semibold text-center text-cyber-muted py-8">
        {placeholder}
      </p>
    </div>
  ) : (
    <div class="relative flex-grow mb-4 desc-container" data-full={project.description} data-trunc={truncatedDesc}>
      <p class="desc text-sm text-cyber-muted leading-relaxed text-justify">{truncatedDesc}</p>
      {project.description.length > truncatedDesc.length && (
        <button class="show-more mt-2 text-xs font-mono text-cyber-blue hover:underline" aria-expanded="false">Show more</button>
      )}
    </div>
  )}

  <!-- Footer: language + links -->
  <div class="flex items-center justify-between mt-auto pt-3 border-t border-cyber-border/50">
    <div class="flex items-center gap-4">
      <!-- Language -->
      <span class="flex items-center gap-1.5 text-xs text-cyber-muted">
        <span class="w-2.5 h-2.5 rounded-full" style={`background-color: ${dotColor}`}></span>
        {project.language}
      </span>
      {project.stack && (
        <span class="text-xs text-cyber-muted/60 hidden sm:inline">{project.stack}</span>
      )}
    </div>

    <div class="flex items-center gap-2">
      {project.url && (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-cyber-muted hover:text-cyber-green transition-colors"
          aria-label={`View ${project.title} on GitHub`}
        >
          <ExternalLink class="w-4 h-4" />
        </a>
      )}
      {project.homepage && (
        <a
          href={project.homepage}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-xs text-cyber-blue hover:text-cyber-green transition-colors font-mono"
          aria-label={`Live demo of ${project.title}`}
        >
          <Play class="w-3.5 h-3.5" />
          Demo
        </a>
      )}
    </div>
  </div>
</div>

<script>
  // enable expand/collapse description and private blur toggle
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-full]').forEach((card) => {
      const full = card.getAttribute('data-full') || '';
      const trunc = card.getAttribute('data-trunc') || '';
      const desc = card.querySelector('.desc');
      const more = card.querySelector('.show-more');
      // visitor blur toggle button intentionally not used anymore

      if (more && desc) {
        more.addEventListener('click', () => {
          const expanded = more.getAttribute('aria-expanded') === 'true';
          if (expanded) {
            desc.textContent = trunc;
            more.textContent = 'Show more';
            more.setAttribute('aria-expanded', 'false');
          } else {
            desc.textContent = full;
            more.textContent = 'Show less';
            more.setAttribute('aria-expanded', 'true');
          }
        });
      }

      // nothing to do on client; blur rendered conditionally above
    });
  });
</script>
